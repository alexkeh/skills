{
  "version": 2,
  "description": "Smart router for APEXlang skills - determines when to load each domain file",
  "routers": [
    {
      "id": "intent-based",
      "type": "keyword-exact",
      "priority": 10,
      "domains": [
        {"id": "app-from-fr-and-model", "keywords": ["create app from fr", "generate app from requirements"]},
        {"id": "application-settings", "keywords": ["globalization", "session management", "security settings"]},
        {"id": "workspace-components", "keywords": ["credentials", "rest data source", "generative ai"]},
        {"id": "app-composition-workflows", "keywords": ["master-detail", "modal form", "faceted search"]},
        {"id": "form-crud-patterns", "keywords": ["create form", "edit form", "modal form", "drawer form"]},
        {"id": "reporting-and-dashboards", "keywords": ["dashboard", "chart", "interactive report", "kpi card"]},
        {"id": "page-components", "keywords": ["region", "button", "item", "page pattern"]},
        {"id": "business-logic", "keywords": ["dynamic action", "validation", "process", "computation"]},
        {"id": "shared-components", "keywords": ["translate", "translation", "lov", "breadcrumb"]},
        {"id": "debugging", "keywords": ["validate failure", "debug", "runtime error"]}
      ]
    },
    {
      "id": "fallback-readme",
      "type": "keyword-wildcard",
      "priority": 1,
      "domains": [
        {"id": "page-components", "keywords": ["region", "item", "button"]},
        {"id": "business-logic", "keywords": ["action", "validation", "process"]},
        {"id": "shared-components", "keywords": ["component", "list", "breadcrumb"]},
        {"id": "debugging", "keywords": ["error", "debug", "failure"]}
      ]
    }
  ],
  "load-strategy": "least-context-first",
  "context-gates": {
    "needs_db": {"flags": ["needs_db"], "load": "runtime-gates"},
    "has_error": {"flags": ["failure_branch"], "load": "debugging"}
  }
}
